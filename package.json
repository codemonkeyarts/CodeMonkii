{
  "name": "monkii",
  "version": "1.3.2",
  "description": "Monkii — local LLM studio for Ollama: projects, Claude-style skills, and live file knowledge",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "bench": "node scripts/benchmark.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.codalanguez.monkii",
    "productName": "Monkii",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "electron/build"
    },
    "files": [
      "server.js",
      "electron/**/*",
      "lib/**/*",
      "routes/**/*",
      "public/**/*",
      "skills/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Monkii"
    }
  }
}
